{
  "name": "boardgame-platform",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "engines": {
    "node": "24.1.0"
  },
  "scripts": {
    "predev": "node scripts/infra/clean_ports.js && node scripts/game/generate_game_manifests.js && node scripts/audio/generate-slim-registry.mjs && docker compose up -d mongodb",
    "dev": "cross-env NODE_ENV=development node scripts/infra/dev-orchestrator.js",
    "predev:un": "node scripts/infra/clean_ports.js && node scripts/game/generate_game_manifests.js && node scripts/audio/generate-slim-registry.mjs && docker compose up -d mongodb",
    "dev:un": "cross-env NODE_ENV=development concurrently \"npm:dev:game\" \"npm:dev:api\" \"npm:dev:frontend:wait\"",
    "predev:lite": "node scripts/infra/clean_ports.js && node scripts/game/generate_game_manifests.js && node scripts/audio/generate-slim-registry.mjs",
    "dev:lite": "cross-env NODE_ENV=development concurrently \"npm:dev:game:lite\" \"npm:dev:api\" \"npm:dev:frontend:wait\"",
    "db:start": "docker compose up -d mongodb",
    "db:stop": "docker compose stop mongodb",
    "dev:frontend": "node scripts/infra/vite-with-logging.js",
    "dev:frontend:wait": "node scripts/infra/wait_for_ports.js && node scripts/infra/vite-with-logging.js",
    "dev:api": "cross-env NODE_ENV=development node scripts/infra/dev-bundle-runner.mjs --label api --entry apps/api/src/main.ts --outfile temp/dev-bundles/api/main.mjs --tsconfig apps/api/tsconfig.json",
    "dev:game": "cross-env NODE_ENV=development node scripts/infra/dev-bundle-runner.mjs --label game --entry server.ts --outfile temp/dev-bundles/game/server.mjs --tsconfig tsconfig.server.json",
    "dev:game:nodemon": "cross-env NODE_ENV=development nodemon --config nodemon.json",
    "smoke:startup": "node scripts/infra/startup-smoke-test.mjs",
    "prebuild": "node scripts/game/generate_game_manifests.js && node scripts/audio/generate-slim-registry.mjs",
    "build": "vite build",
    "build:full": "tsc -b && npx vite build",
    "lint": "eslint .",
    "clean:ports": "node scripts/infra/clean_ports.js",
    "generate:manifests": "node scripts/game/generate_game_manifests.js",
    "generate:locales": "node scripts/game/generate-card-locales.cjs",
    "assets:manifest": "node scripts/assets/generate_asset_manifests.js",
    "assets:validate": "node scripts/assets/generate_asset_manifests.js --validate",
    "preview": "vite preview",
    "pdf:md": "node scripts/infra/pdf_to_md.js",
    "compress:images": "node scripts/assets/compress_images.js",
    "compress:audio": "node scripts/audio/compress_audio.js",
    "audio:catalog": "node scripts/audio/generate_audio_catalog.js",
    "audio:slim": "node scripts/audio/generate-slim-registry.mjs",
    "audio:verify": "node scripts/audio/verify-slim-registry.mjs",
    "atlas:scan": "node scripts/assets/atlas_grid_scan.js",
    "i18n:check": "npx tsx scripts/verify/i18n-check.ts",
    "check:all": "npm run typecheck && npm run lint",
    "quality:changed": "node scripts/infra/run-changed-quality-gate.mjs",
    "check:full": "npm run check:all && npm run test:games:core:full",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:core": "vitest run src/core src/components src/hooks src/lib src/shared src/engine src/pages",
    "test:smashup": "vitest run src/games/smashup",
    "test:summonerwars": "vitest run src/games/summonerwars",
    "test:dicethrone": "vitest run src/games/dicethrone",
    "test:tictactoe": "vitest run src/games/tictactoe",
    "test:server": "vitest run src/server src/api",
    "test:ugc": "vitest run src/ugc",
    "test:games": "vitest run src/games",
    "test:games:core": "npx vitest run --changed origin/main --config vitest.config.core.ts --pool threads --no-file-parallelism --maxWorkers 1 -- src/games",
    "test:games:core:full": "cross-env NODE_OPTIONS=--max-old-space-size=8192 npx vitest run src/games --config vitest.config.core.ts --pool threads --no-file-parallelism --maxWorkers 1 --testTimeout 300000 --hookTimeout 300000",
    "test:games:audit": "vitest run src/games --config vitest.config.audit.ts",
    "test:changed": "npx vitest run --changed origin/main -- src/games",
    "test:api": "vitest run apps/api",
    "test:api:docker": "cross-env MONGO_URI=mongodb://localhost:27017/boardgame npm run test:api",
    "check:encoding": "node scripts/infra/check-file-encoding.mjs",
    "check:encoding:fix": "node scripts/infra/check-file-encoding.mjs --fix-bom",
    "check:encoding:strict": "node scripts/infra/check-file-encoding.mjs --strict",
    "check:child-process:e2e": "node scripts/infra/assert-child-process-support.mjs E2E --probe-fork --probe-esbuild",
    "test:e2e": "node scripts/infra/run-e2e-command.mjs default",
    "test:e2e:all": "cross-env PW_ALLOW_FULL_RUN=true node scripts/infra/run-e2e-command.mjs default",
    "test:e2e:dev": "node scripts/infra/run-e2e-command.mjs dev",
    "test:e2e:dev:file": "node scripts/infra/run-e2e-dev-single.js",
    "test:e2e:isolated": "node scripts/infra/run-e2e-command.mjs isolated",
    "test:e2e:ci": "node scripts/infra/run-e2e-command.mjs ci",
    "test:e2e:ci:all": "cross-env PW_ALLOW_FULL_RUN=true node scripts/infra/run-e2e-command.mjs ci",
    "test:e2e:critical": "node scripts/infra/run-e2e-command.mjs critical",
    "test:e2e:cleanup": "node scripts/infra/cleanup_test_connections.js",
    "test:e2e:parallel": "node scripts/infra/run-e2e-command.mjs parallel",
    "test:e2e:worker": "npm run check:child-process:e2e && node scripts/infra/start-worker-servers.js",
    "test:e2e:check": "node scripts/infra/check-e2e-safety.js",
    "init:admin": "npx tsx scripts/db/init_admin.ts",
    "check:arch": "node scripts/infra/check-architecture.cjs",
    "check:prod-deps": "bash scripts/deploy/verify-prod-deps.sh",
    "check:jwt": "node scripts/check-jwt-config.mjs",
    "diagnose:auth": "node scripts/diagnose-auth.mjs",
    "debug:token": "node scripts/debug-token.mjs",
    "build:android:web": "vite build --mode android",
    "mobile:android:doctor": "node scripts/mobile/android.mjs doctor",
    "mobile:android:assets": "node scripts/mobile/android.mjs assets",
    "mobile:android:prepare-release": "node scripts/mobile/android.mjs prepare-release",
    "mobile:android:init": "node scripts/mobile/android.mjs init",
    "mobile:android:sync": "node scripts/mobile/android.mjs sync",
    "mobile:android:open": "node scripts/mobile/android.mjs open",
    "mobile:android:run": "node scripts/mobile/android.mjs run",
    "mobile:android:build:debug": "node scripts/mobile/android.mjs build-debug",
    "mobile:android:build:release": "node scripts/mobile/android.mjs build-release",
    "mobile:android:build:bundle": "node scripts/mobile/android.mjs build-bundle",
    "typecheck": "tsc --noEmit",
    "assets:download": "node scripts/assets/download-from-r2.js",
    "assets:upload": "node scripts/assets/upload-to-r2.js",
    "assets:upload:force": "cross-env FORCE_UPLOAD=1 node scripts/assets/upload-to-r2.js",
    "assets:check": "node scripts/assets/upload-to-r2.js --check",
    "assets:sync": "node scripts/assets/upload-to-r2.js --sync",
    "monitor:kiro:timer:test": "powershell -ExecutionPolicy Bypass -File scripts/kiro-auto-timer.ps1 -IntervalMinutes 0.17 -MaxRetries 5",
    "monitor:kiro:timer:20min": "powershell -ExecutionPolicy Bypass -File scripts/kiro-auto-timer.ps1 -IntervalMinutes 20 -MaxRetries 20",
    "monitor:kiro:timer:30min": "powershell -ExecutionPolicy Bypass -File scripts/kiro-auto-timer.ps1 -IntervalMinutes 30 -MaxRetries 20",
    "prepare": "simple-git-hooks",
    "dev:parallel": "concurrently \"npm:dev:game\" \"npm:dev:api\" \"npm:dev:frontend:wait\"",
    "dev:game:lite": "cross-env NODE_ENV=development USE_PERSISTENT_STORAGE=false node scripts/infra/dev-bundle-runner.mjs --label game-lite --entry server.ts --outfile temp/dev-bundles/game-lite/server.mjs --tsconfig tsconfig.server.json"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged --concurrent 1 --no-stash",
    "pre-push": "npm run quality:changed"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "cross-env NODE_OPTIONS=--max-old-space-size=4096 eslint --max-warnings 999"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.975.0",
    "@babel/standalone": "^7.29.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/screen-orientation": "^8.0.1",
    "@koa/router": "^15.3.0",
    "@nestjs/cache-manager": "^2.2.1",
    "@nestjs/common": "^10.3.9",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.9",
    "@nestjs/mongoose": "^10.0.2",
    "@nestjs/platform-express": "^10.3.9",
    "@nestjs/platform-socket.io": "^10.3.9",
    "@nestjs/websockets": "^10.3.9",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@sentry/browser": "^10.38.0",
    "@sentry/nestjs": "^10.38.0",
    "@sentry/react": "^10.38.0",
    "@tanstack/react-query": "^5.90.20",
    "bcryptjs": "^3.0.3",
    "cache-manager": "^5.4.0",
    "cache-manager-redis-store": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "fast-json-patch": "^3.1.1",
    "fflate": "^0.8.2",
    "framer-motion": "^12.27.1",
    "howler": "^2.2.4",
    "http-proxy-middleware": "^3.0.5",
    "i18next": "^25.5.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "jsonwebtoken": "^9.0.3",
    "koa": "^3.1.1",
    "koa-bodyparser": "^4.4.1",
    "lucide-react": "^0.562.0",
    "mime-types": "^2.1.35",
    "mongoose": "^8.21.1",
    "nanoid": "^3.3.11",
    "nodemailer": "^7.0.12",
    "oh-my-live2d": "^0.19.3",
    "pdf-parse": "^1.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.6",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^15.7.4",
    "react-router-dom": "^7.12.0",
    "recharts": "^3.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "socket.io-msgpack-parser": "^3.0.2",
    "tailwind-merge": "^3.4.0",
    "three": "^0.182.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "overrides": {
    "is-generator-function": "1.0.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@eslint/js": "^9.39.1",
    "@nestjs/testing": "^10.3.9",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/babel__standalone": "^7.1.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/howler": "^2.2.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/koa": "^3.0.1",
    "@types/koa__router": "^12.0.5",
    "@types/koa-bodyparser": "^4.3.13",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^7.0.5",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fast-check": "^4.5.3",
    "globals": "^16.5.0",
    "happy-dom": "^20.5.3",
    "jest-util": "^29.7.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "mongodb-memory-server": "^9.3.0",
    "nodemon": "^3.1.11",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "simple-git-hooks": "^2.13.1",
    "supertest": "^6.3.4",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-node": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  }
}
